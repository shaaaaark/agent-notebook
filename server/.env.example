NODE_ENV=development
PORT=3000
CHUNK_SIZE=500
CHUNK_STEP=200
RETRIEVE_TOP_K=8
RETRIEVE_TOP_K_VEC=50
RETRIEVE_TOP_K_BM25=50
RETRIEVE_FUSED_TOP_N=30
RETRIEVE_RRF_K=60
RERANK_TOP_M=8
MAX_CONTEXT_TOKENS=2000
MAX_CHUNKS_PER_SOURCE=2
COVERAGE_MIN_GAIN=0.05
ABSTAIN_THRESHOLD=0.35
RETRIEVE_TIMEOUT_MS=3000
RERANK_TIMEOUT_MS=500
LLM_TIMEOUT_MS=10000
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini
# 可选：为 embedding 单独指定 provider；未设置时回退到 OPENAI_* 配置
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RERANK_PROVIDER=bailian
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
BAILIAN_RERANK_BASE_URL=https://dashscope.aliyuncs.com
BAILIAN_RERANK_API_KEY=
BAILIAN_RERANK_MODEL=qwen3-vl-rerank
LLM_MAX_TOKENS=1024
VECTOR_STORE=memory
# Trace 日志目录，为空时使用 server 包根目录下的 logs/traces
TRACE_LOG_DIR=
SCHEDULE_TIMEZONE=Asia/Shanghai
REVIEW_CRON=0 20 * * *
